                  "span": [
                    313,
                    2,
                    36,
                  ],
                  "trailingComments": "",
                },
                {
                  "leadingComments": " If set, gives the index of a oneof in the containing type's oneof_decl
 list.  This field is a member of that oneof.
",
                  "leadingDetachedComments": [],
                  "path": [
                    4,
